# ─── HikCentral connection ────────────────────────────────────────────────────
HIK_BASE_URL=http://10.25.1.30
HIK_HOSTNAME=10.25.1.30

# ─── Auto-login credentials (used by /api/login and session watcher) ──────────
HIK_USERNAME=admin_trk
HIK_PASSWORD=

# ─── Bootstrap session (optional — used only if session.json is absent) ───────
# Grab SID and encrypted key from browser localStorage after manual login:
#   localStorage["80_pro_system_session_id"]
#   localStorage["80_pro_system_session_token"]  ← encrypted AES key (base64)
HIK_SID=
HIK_ENCRYPTED_AES_KEY=
